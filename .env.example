# AI Document Classifier - Environment Configuration Reference
# This file documents all environment variables used across the project
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env (do NOT commit .env files!)
# 2. Fill in actual values for each environment
# 3. Create .env files in: client/, server/, and ml_service/ folders
# 4. Never commit .env files - they're gitignored

# ================================================
# CLIENT (React/Vite) - client/.env.local
# ================================================
# VITE_API_BASE_URL=http://localhost:5000
# VITE_API_TIMEOUT=30000
# VITE_APP_NAME=AI Document Classifier
# VITE_ENABLE_DEBUG=false

# ================================================
# SERVER (Node.js/Express) - server/.env
# ================================================
# NODE_ENV=development
# PORT=5000
# MONGODB_URI=mongodb://localhost:27017/ai-document-classifier
# JWT_SECRET=<generate-random-secret>
# JWT_EXPIRE=7d
# CLIENT_URL=http://localhost:3000
# ML_SERVICE_URL=http://localhost:5001
# UPLOAD_TEMP_DIR=./uploads/temp
# UPLOAD_PERMANENT_DIR=./uploads/documents
# LOG_LEVEL=info

# ================================================
# ML SERVICE (Python/Flask) - ml_service/.env
# ================================================
# FLASK_ENV=development
# DEBUG=False
# SECRET_KEY=<generate-random-secret>
# PORT=5001
# HOST=0.0.0.0
# DEVICE=cpu  # or 'cuda' for GPU
# UPLOAD_DIR=./config/uploads
# LOG_LEVEL=INFO
# LOG_FILE=./config/logs/ml_service.log

# ================================================
# PRODUCTION SETUP
# ================================================
# For production deployment:
# - Use environment-specific .env.prod files
# - Store secrets in platform secrets manager (GitHub Secrets, AWS Secrets Manager, etc.)
# - Never expose credentials in code or version control
# - Use strong, randomly generated JWT_SECRET
# - Update MONGODB_URI to production database
# - Set NODE_ENV=production
# - Set FLASK_ENV=production
