# Flask Configuration
FLASK_ENV=development
DEBUG=False
SECRET_KEY=dev-secret-key-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5001
THREADED=True

# Model Configuration
DEVICE=cpu
# Set to 'cuda' if GPU is available
# DEVICE=cuda

# Model Paths
STACK_MODEL_PATH=./config/models/stack_model.pkl
LABEL_ENCODER_PATH=./config/models/label_encoder.pkl

# File Upload Configuration
UPLOAD_DIR=./config/uploads
MAX_FILE_SIZE=10485760

# PDF Processing Configuration
PDF_MAX_PAGES=100
PDF_TEXT_MIN_LENGTH=10

# Model Inference Configuration
CONFIDENCE_THRESHOLD=0.0
PREDICTION_TIMEOUT=60

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./config/logs/ml_service.log

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
